{
  "name": "keyboard-shortcut-manager",
  "version": "1.0.0",
  "description": "Chrome keyboard shortcut manager extension",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.e2e.config.js",
    "test:e2e:ui": "HEADLESS=false npm run test:e2e"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "puppeteer": "^22.15.0"
  }
}
